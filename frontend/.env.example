# Required
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required in production when frontend and backend are on different domains.
# Example: https://xcraper-api.onrender.com
VITE_API_URL=http://localhost:3001

# Optional fallback. You can now store this in admin system settings instead.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional fallback. You can now store this in admin system settings instead.
VITE_SENTRY_DSN=
