# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xcraper
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
APIFY_API_TOKEN=your-apify-api-token
FRONTEND_URL=http://localhost:5173

# Required if you use these features
GOOGLE_PLACES_API_KEY=your-google-places-api-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PAYMENTS_WEBHOOK_SECRET=your-stripe-payments-webhook-secret
STRIPE_SUBSCRIPTIONS_WEBHOOK_SECRET=your-stripe-subscriptions-webhook-secret

# Recommended
ADMIN_EMAIL=admin@example.com
BACKEND_URL=http://localhost:3001
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# Optional
SENTRY_DSN=
CREDITS_PER_SEARCH=1
CREDITS_PER_CONTACT=1
