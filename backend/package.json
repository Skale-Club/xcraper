{
    "name": "backend",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc && tsc-alias",
        "start": "node dist/index.js",
        "db:generate": "drizzle-kit generate --config drizzle.config.ts",
        "db:push": "drizzle-kit push --config drizzle.config.ts",
        "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
        "db:studio": "drizzle-kit studio",
        "db:seed": "tsx src/scripts/seed-settings.ts",
        "stripe:sync": "tsx src/scripts/sync-stripe-catalog.ts",
        "stripe:listen:payments": "stripe listen --events checkout.session.completed,payment_intent.succeeded,payment_intent.payment_failed --forward-to http://localhost:3001/api/payments/webhook",
        "stripe:listen:subscriptions": "stripe listen --events checkout.session.completed,customer.subscription.updated,customer.subscription.deleted,invoice.paid,invoice.payment_failed --forward-to http://localhost:3001/api/subscriptions/webhook",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.39.8",
        "@types/express-session": "^1.18.0",
        "apify-client": "^2.9.3",
        "connect-pg-simple": "^9.0.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "drizzle-orm": "^0.45.1",
        "drizzle-zod": "^0.8.3",
        "express": "^4.18.3",
        "express-rate-limit": "^7.2.0",
        "express-session": "^1.18.0",
        "helmet": "^7.1.0",
        "morgan": "^1.10.0",
        "multer": "^2.1.1",
        "pg": "^8.11.3",
        "stripe": "^14.18.0",
        "uuid": "^9.0.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/connect-pg-simple": "^7.0.3",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^2.1.0",
        "@types/node": "^20.11.24",
        "@types/pg": "^8.11.2",
        "@types/uuid": "^9.0.8",
        "drizzle-kit": "^0.31.9",
        "tsc-alias": "^1.8.8",
        "tsx": "^4.7.1",
        "typescript": "^5.3.3",
        "vitest": "^1.3.1",
        "@vitest/coverage-v8": "^1.3.1",
        "supertest": "^6.3.4",
        "@types/supertest": "^6.0.2"
    }
}